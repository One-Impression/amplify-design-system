{
  "semantic": {
    "$type": "color",
    "accent":          { "$value": "{color.violet.600}", "$description": "#7C3AED — primary accent" },
    "accent-hover":    { "$value": "{color.violet.700}", "$description": "Accent on hover" },
    "accent-light":    { "$value": "{color.violet.100}", "$description": "Accent tint backgrounds" },
    "accent-subtle":   { "$value": "{color.violet.50}",  "$description": "Subtle accent bg" },

    "bg-primary":      { "$value": "{color.stone.50}",   "$description": "#FAFAF9 — page background" },
    "bg-surface":      { "$value": "{color.white}",      "$description": "Card/panel surface" },
    "bg-raised":       { "$value": "{color.white}",      "$description": "Elevated surfaces" },
    "bg-sunken":       { "$value": "{color.stone.100}",  "$description": "Inset/recessed areas" },
    "bg-overlay":      { "$value": "rgba(28, 25, 23, 0.5)", "$description": "Modal backdrop" },

    "text-primary":    { "$value": "{color.stone.900}",  "$description": "#1C1917 — main text" },
    "text-secondary":  { "$value": "{color.stone.600}",  "$description": "Secondary text" },
    "text-muted":      { "$value": "{color.stone.500}",  "$description": "Muted/placeholder" },
    "text-disabled":   { "$value": "{color.stone.400}",  "$description": "Disabled text" },
    "text-inverse":    { "$value": "{color.white}",      "$description": "Text on dark bg" },
    "text-accent":     { "$value": "{color.violet.600}", "$description": "Links, active items" },

    "border-default":  { "$value": "{color.stone.200}",  "$description": "#E7E5E4 — card borders" },
    "border-strong":   { "$value": "{color.stone.300}",  "$description": "Stronger borders" },
    "border-subtle":   { "$value": "{color.stone.100}",  "$description": "Very subtle dividers" },
    "border-accent":   { "$value": "{color.violet.200}", "$description": "Accent borders" },
    "border-focus":    { "$value": "{color.violet.600}", "$description": "Focus ring" },

    "status-success":       { "$value": "{color.green.600}" },
    "status-success-bg":    { "$value": "rgba(5, 150, 105, 0.08)" },
    "status-warning":       { "$value": "{color.amber.600}" },
    "status-warning-bg":    { "$value": "rgba(217, 119, 6, 0.08)" },
    "status-error":         { "$value": "{color.red.600}" },
    "status-error-bg":      { "$value": "rgba(220, 38, 38, 0.08)" },
    "status-info":          { "$value": "{color.blue.600}" },
    "status-info-bg":       { "$value": "rgba(37, 99, 235, 0.08)" }
  }
}
