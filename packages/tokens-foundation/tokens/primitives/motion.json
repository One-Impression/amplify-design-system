{
  "motion": {
    "duration": {
      "$type": "duration",
      "instant": { "$value": "50ms",  "$description": "Micro-interactions" },
      "fast":    { "$value": "150ms", "$description": "Hover, focus" },
      "normal":  { "$value": "250ms", "$description": "Transitions" },
      "slow":    { "$value": "400ms", "$description": "Page transitions, fade-in" },
      "slower":  { "$value": "600ms", "$description": "Complex animations" }
    },
    "easing": {
      "$type": "cubicBezier",
      "ease-out":    { "$value": [0.0, 0.0, 0.2, 1.0], "$description": "Deceleration — elements entering" },
      "ease-in":     { "$value": [0.4, 0.0, 1.0, 1.0], "$description": "Acceleration — elements exiting" },
      "ease-in-out": { "$value": [0.4, 0.0, 0.2, 1.0], "$description": "Balanced — state changes" },
      "spring":      { "$value": [0.175, 0.885, 0.32, 1.275], "$description": "Bouncy — playful interactions" }
    },
    "stagger": {
      "$type": "duration",
      "delay": { "$value": "50ms", "$description": "Per-child stagger delay for lists/grids" }
    }
  }
}
