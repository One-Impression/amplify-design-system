{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans":  { "$value": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" },
      "mono":  { "$value": "'JetBrains Mono', 'SF Mono', Monaco, Menlo, monospace" }
    },
    "weight": {
      "$type": "fontWeight",
      "light":    { "$value": 300 },
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "display": { "$value": "34px", "$description": "Hero/page titles" },
      "h-lg":    { "$value": "24px", "$description": "Section headers" },
      "h-md":    { "$value": "18px", "$description": "Card titles" },
      "h-sm":    { "$value": "15px", "$description": "Sub-headers" },
      "body":    { "$value": "14px", "$description": "Default body — compact" },
      "body-sm": { "$value": "12px", "$description": "Captions, helper text" },
      "mono":    { "$value": "13px", "$description": "Code, data" }
    },
    "lineHeight": {
      "$type": "number",
      "tight":   { "$value": 1.2, "$description": "Headings, metrics" },
      "normal":  { "$value": 1.5, "$description": "General text" },
      "relaxed": { "$value": 1.6, "$description": "Body text, paragraphs" }
    }
  }
}
