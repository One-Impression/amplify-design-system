{
  "radius": {
    "$type": "dimension",
    "none": { "$value": "0px" },
    "sm":   { "$value": "4px" },
    "md":   { "$value": "8px" },
    "lg":   { "$value": "12px" },
    "xl":   { "$value": "16px", "$description": "Default — soft, Canvas signature" },
    "2xl":  { "$value": "20px", "$description": "Mobile cards, bottom sheets" },
    "full": { "$value": "9999px", "$description": "Circles, pills" }
  }
}
