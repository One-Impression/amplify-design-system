{
  "name": "@amplify/mcp-server",
  "version": "2.0.0",
  "description": "MCP server exposing the Amplify Canvas design system to AI agents (Pixel, Claude Code).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    }
  },
  "bin": {
    "amplify-mcp": "dist/index.js",
    "amplify-mcp-http": "dist/http.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts src/http.ts --format esm --dts --external @modelcontextprotocol/sdk",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "test": "tsx --test tests/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
