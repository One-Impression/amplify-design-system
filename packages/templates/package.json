{
  "name": "@amplify/templates",
  "version": "2.0.0",
  "description": "React SSR template engine for instant interactive mockups \u2014 100% Canvas design system compliant",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react --external react-dom && npm run build:html",
    "build:html": "tsx src/build.tsx",
    "dev": "tsx watch src/dev-server.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@amplify/ui": "^2.0.0",
    "@amplify/tokens-brand": "^2.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
