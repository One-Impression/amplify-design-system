{
  "theme": {
    "$description": "Creator App — Dark theme (warm charcoal, mobile-optimized)",
    "product": "creator",
    "mode": "dark",
    "color": {
      "$type": "color",
      "accent":          { "$value": "{color.violet.500}" },
      "accent-hover":    { "$value": "{color.violet.400}" },
      "accent-light":    { "$value": "rgba(168, 85, 247, 0.12)" },
      "bg-primary":      { "$value": "{color.stone.900}" },
      "bg-surface":      { "$value": "{color.stone.800}" },
      "bg-raised":       { "$value": "{color.stone.700}" },
      "text-primary":    { "$value": "{color.stone.200}" },
      "text-secondary":  { "$value": "{color.stone.400}" },
      "text-muted":      { "$value": "{color.stone.500}" },
      "border-default":  { "$value": "{color.stone.700}" },
      "border-accent":   { "$value": "rgba(168, 85, 247, 0.3)" }
    }
  },
  "sdui": {
    "$description": "SDUI dark mode color mapping",
    "color": {
      "$type": "color",
      "neutral-strong":  { "$value": "{color.stone.200}" },
      "neutral-medium":  { "$value": "{color.stone.400}" },
      "neutral-weak":    { "$value": "{color.stone.600}" },
      "neutral-subtle":  { "$value": "{color.stone.700}" },
      "neutral-inverse": { "$value": "{color.stone.900}" },
      "primary":         { "$value": "{color.violet.500}" },
      "primary-weak":    { "$value": "rgba(168, 85, 247, 0.12)" },
      "positive":        { "$value": "{color.green.500}" },
      "positive-weak":   { "$value": "rgba(16, 185, 129, 0.12)" },
      "notice":          { "$value": "{color.amber.500}" },
      "notice-weak":     { "$value": "rgba(245, 158, 11, 0.12)" },
      "negative":        { "$value": "{color.red.500}" },
      "negative-weak":   { "$value": "rgba(239, 68, 68, 0.12)" },
      "offset-strong":   { "$value": "{color.stone.700}" },
      "offset-medium":   { "$value": "{color.stone.800}" },
      "offset-weak":     { "$value": "{color.stone.900}" },
      "transparent":     { "$value": "transparent" }
    }
  }
}
