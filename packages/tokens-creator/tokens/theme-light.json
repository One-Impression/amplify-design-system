{
  "theme": {
    "$description": "Creator App — Light theme (warm cream, mobile-optimized)",
    "product": "creator",
    "mode": "light",
    "color": {
      "$type": "color",
      "accent":          { "$value": "{color.violet.600}" },
      "accent-hover":    { "$value": "{color.violet.700}" },
      "accent-light":    { "$value": "{color.violet.100}" },
      "bg-primary":      { "$value": "#FFFBF5", "$description": "Warm cream page bg" },
      "bg-surface":      { "$value": "{color.white}" },
      "bg-raised":       { "$value": "{color.stone.50}" },
      "text-primary":    { "$value": "{color.stone.900}" },
      "text-secondary":  { "$value": "{color.stone.600}" },
      "text-muted":      { "$value": "{color.stone.500}" },
      "border-default":  { "$value": "{color.stone.200}" },
      "border-accent":   { "$value": "{color.violet.200}" }
    }
  },
  "sdui": {
    "$description": "SDUI color mapping — backward compatible with api-gateway ColorType enum",
    "color": {
      "$type": "color",
      "neutral-strong":  { "$value": "{color.stone.900}" },
      "neutral-medium":  { "$value": "{color.stone.500}" },
      "neutral-weak":    { "$value": "{color.stone.300}" },
      "neutral-subtle":  { "$value": "{color.stone.200}" },
      "neutral-inverse": { "$value": "{color.white}" },
      "primary":         { "$value": "{color.violet.600}" },
      "primary-weak":    { "$value": "{color.violet.100}" },
      "positive":        { "$value": "{color.green.600}" },
      "positive-weak":   { "$value": "{color.green.50}" },
      "notice":          { "$value": "{color.amber.600}" },
      "notice-weak":     { "$value": "{color.amber.50}" },
      "negative":        { "$value": "{color.red.600}" },
      "negative-weak":   { "$value": "{color.red.50}" },
      "offset-strong":   { "$value": "{color.stone.200}" },
      "offset-medium":   { "$value": "#F1F6FE" },
      "offset-weak":     { "$value": "#F6FAFF" },
      "transparent":     { "$value": "transparent" }
    }
  }
}
